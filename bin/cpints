#!/bin/bash
#
# Script to run a pint self compile
#
# When REGRESS_OUT is set (a parallel per-model regress run), all generated
# files (the cpp'd source, intermediates, combined deck, .lst/.dif and temps)
# go to that per-model directory; the pint.pas/iso7185pat.pas sources and the
# .cmp gold are read canonically. When unset, everything stays under source/ and
# standard_tests/ as before.
#
if [ -n "$REGRESS_OUT" ]; then tmpd="$REGRESS_OUT/"
else tmpd=""; fi
ob() { if [ -n "$REGRESS_OUT" ]; then echo "$REGRESS_OUT/$(basename "$1")"; else echo "$1"; fi; }

#
# First, change elide patterns to #ove prd and prr file statements.
# The modified file goes in pint.mpp.pas (pint modified).
#
cpp -DSELF_COMPILE -DWRDSIZ64 -P -nostdinc -traditional-cpp source/pint.pas $(ob source/pint.mpp).pas
#
# Compile the final target, the PAT. The iso7185pat.pas source is read
# canonically; compile redirects its products into REGRESS_OUT.
#
echo Compiling the ISO 7185 PAT
compile --out="$REGRESS_OUT" $1 standard_tests/iso7185pat
if [ $? -ne 0 ]
then

    echo "*** Compile failed"
    cat $(ob standard_tests/iso7185pat).err
    exit 1

fi
#
# Compile pint itself
#
echo Compiling pint to intermediate code
compile --out="$REGRESS_OUT" $1 $(ob source/pint.mpp)
if [ $? -ne 0 ]
then

    echo "*** Compile failed"
    cat $(ob source/pint.mpp).err
    exit 1

fi
#
# Add the final target program (the pat) to the end of pint.
# This means that the version of pint will read and interpret
# this.
#
cat $(ob source/pint.mpp).p6 $(ob standard_tests/iso7185pat).p6 > ${tmpd}tmp.p6
rm $(ob source/pint.mpp).p6
mv ${tmpd}tmp.p6 $(ob source/pint.mpp).p6
#
# Create null input file
#
echo > $(ob source/pint.mpp).inp
#
# Now run pint on pint, which runs the PAT.
#
echo Running pint on itself, to run the ISO 7185 PAT
run $1 $(ob source/pint.mpp)
cp $(ob source/pint.mpp).lst $(ob standard_tests/iso7185pats).lst
echo -n "Comparing PAT result to reference ... "
diffnole $(ob standard_tests/iso7185pats).lst standard_tests/iso7185pats.cmp > $(ob standard_tests/iso7185pats).dif
if test -s $(ob standard_tests/iso7185pats).dif
then
    echo FAILED
else
    echo PASS
fi

#
# Show the file, so if the length is zero, it compared ok.
#
#echo Resulting diff file length should be zero for pass
#ls -l standard_tests/iso7185pats.dif
