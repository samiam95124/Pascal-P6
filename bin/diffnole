#!/bin/bash
#
# Difference without line endings
#
# Same as diff, but ignores the DOS/Unix line ending differences. Uses the dif
# utility (utils/dif.pas), which normalizes line endings itself, so no temporary
# files are needed -- this makes it safe to run concurrently (several regression
# models call it at once from the same working directory).
#

if [ -z "$1" ]
then

   echo "*** Error: Missing parameter 1"
   echo "*** s/b \"diffnole <file1> <file2>\""
   exit 1

fi

if [ ! -f $1 ]
then
   echo "*** Error: Missing $1 file"
   exit 1
fi

if [ -z "$2" ]
then

   echo "*** Error: Missing parameter 2"
   echo "*** s/b \"diffnole <file1> <file2>\""
   exit 1

fi

if [ ! -f $2 ]
then
   echo "*** Error: Missing $2 file"
   exit 1
fi

dif "$1" "$2"
