#!/bin/bash
#
# Difference without line endings
#
# Same as diff, but ignores the DOS/Unix line ending differences. All
# temporaries are unique per-invocation (mktemp) so this is safe to run
# concurrently -- several regression models call it at once from the same
# working directory, and the old fixed tmp1/tmp2 names would collide.
#

if [ -z "$1" ]
then

   echo "*** Error: Missing parameter 1"
   echo "*** s/b \"diffnole <file1> <file2>\""
   exit 1

fi

if [ ! -f $1 ]
then
   echo "*** Error: Missing $1 file"
   exit 1
fi

if [ -z "$2" ]
then

   echo "*** Error: Missing parameter 2"
   echo "*** s/b \"diffnole <file1> <file2>\""
   exit 1

fi

if [ ! -f $2 ]
then
   echo "*** Error: Missing $2 file"
   exit 1
fi

tmp1=`mktemp`
tmp2=`mktemp`
cp "$1" "$tmp1"
cp "$2" "$tmp2"
flip -u -b "$tmp1"
flip -u -b "$tmp2"
diff "$tmp1" "$tmp2"
status=$?
rm -f "$tmp1" "$tmp2"
exit $status
