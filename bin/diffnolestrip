#!/bin/bash
#
# Difference without line endings and strip
#
# Same as diff, but ignores the DOS/Unix line ending differences.
# Strips decorations from the files, see the strip script.
#
# The stripped files go to unique per-invocation temporaries (mktemp) and the
# comparison uses the dif utility (utils/dif.pas), which normalizes line endings
# itself. This makes it safe to run concurrently -- several regression models
# call it at once from the same working directory, so fixed temp names (the old
# tmp1/tmp2) would collide and cross-contaminate results.
#

if [ -z "$1" ]
then

   echo "*** Error: Missing parameter 1"
   echo "*** s/b \"diffnolestrip <file1> <file2>\""
   exit 1

fi

if [ ! -f $1 ]
then
   echo "*** Error: Missing $1 file"
   exit 1
fi

if [ -z "$2" ]
then

   echo "*** Error: Missing parameter 2"
   echo "*** s/b \"diffnolestrip <file1> <file2>\""
   exit 1

fi

if [ ! -f $2 ]
then
   echo "*** Error: Missing $2 file"
   exit 1
fi

tmp1s=`mktemp`
tmp2s=`mktemp`
strip "$1" "$tmp1s"
strip "$2" "$tmp2s"
dif -w "$tmp1s" "$tmp2s"
status=$?
rm -f "$tmp1s" "$tmp2s"
exit $status
