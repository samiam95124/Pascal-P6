#!/bin/bash
#
# General build script for Pascal-P6
#
# Form:
# 
# build [<options for make>] [<options for pc>]
#
# Note: if you want to give multiple options for make or pc, surround in quotes
# like:
#
# build "-Bi" "-r -d"
#
function compprog {

   echo ""
   echo "**********************************************************************"
   echo "Building $1..."
   echo "**********************************************************************"
   echo ""
   pc $1 $OPTIONS
   if [ $? -ne 0 ]; then

      echo "*** Error: compile failed"
      exit 1

   fi
   cp $1 bin

}

OPTIONS=$2

make clean
make $1
if [ $? -ne 0 ]; then

   echo "*** Error: make failed"
   exit 1

fi

#
# Build dummy decks to satisfy pc builds.
#
echo ""
echo "**********************************************************************"
echo "Building Dummy decks..."
echo "**********************************************************************"
echo ""
pc libs/source/services -pint -r
cp libs/source/services.p6 libs
pc libs/source/terminal -pint -r
cp libs/source/terminal.p6 libs
pc libs/source/graphics -pint -r
cp libs/source/graphics.p6 libs
pc libs/source/sound -pint -r
cp libs/source/sound.p6 libs
pc libs/source/network -pint -r
cp libs/source/network.p6 libs

#
# General library modules in Pascaline.
# These are compiled to objects and intermediates both because they can be used
# in executables and interpretation.
#
echo ""
echo "**********************************************************************"
echo "Building Strings..."
echo "**********************************************************************"
echo ""
pc libs/source/strings -r
cp libs/source/strings.o libs
pc libs/source/strings -pint -r
cp libs/source/strings.p6 libs

echo ""
echo "**********************************************************************"
echo "Building Parse..."
echo "*******************************************s***************************"
echo ""
pc libs/source/parse -r
cp libs/source/parse.o libs
pc libs/source/parse -pint -r
cp libs/source/parse.p6 libs

#
# Programs in Pascaline.
#
compprog pc/pc
compprog pc/hashtabr
compprog pc/hashtabs
compprog source/genobj
#
# Test programs in libs/tests: build each as a native executable and place it
# in bin. pc detects each program's modules (graphics, sound, network,
# terminal, services) and links the matching libraries, so windowed, sound and
# network tests build the same way. Listed explicitly; add a new libs/tests
# program here to have it built and installed in bin.
#
compprog libs/tests/find_getpgm
compprog libs/tests/graphics_test
compprog libs/tests/management_test
compprog libs/tests/netprobe
compprog libs/tests/network_test
compprog libs/tests/services_test1
compprog libs/tests/services_test
compprog libs/tests/sndprobe
compprog libs/tests/sound_test
compprog libs/tests/strings_test
compprog libs/tests/terminal_test
compprog libs/tests/widget_test
#
# Graphical games in graph_games: build each as a native executable and place it
# in bin, same as the library tests. They use the graphics (and sound) modules;
# pc links the matching libraries.
#
compprog graph_games/backgammon
compprog graph_games/breakout
compprog graph_games/checkers
compprog graph_games/chess
compprog graph_games/conquest
compprog graph_games/defenders
compprog graph_games/pong
#
# Install the chess piece bitmaps next to the chess binary in bin. chess locates
# its assets in its own program directory (getpgm), so the data must travel with
# the installed binary.
#
cp -r graph_games/chess_pieces bin/
#
# pgen and pcom must be a matched set
#
cp bin/pgen pgen.old
compprog source/pgen/amd64/pgen
cp source/pgen/amd64/pgen bin/pgen_amd64
cp bin/pgen pgen.new
cp pgen.old bin/pgen
compprog source/pcom
#
# Now regular
#
cp pgen.new bin/pgen
compprog source/pint
#
# pintt is the same source built with the terminal module flavor first on
# the module path (the instruction file appends the plain flavor after it).
# The plain interpreter is rebuilt afterward so source/pint matches its
# instruction file.
#
echo ""
echo "**********************************************************************"
echo "Building source/pint (terminal flavor) as pintt..."
echo "**********************************************************************"
echo ""
pc source/pint -mp=source/term -r $OPTIONS
if [ $? -ne 0 ]; then

   echo "*** Error: compile failed"
   exit 1

fi
cp source/pint bin/pintt
#
# pintg is the graphics-hosted interpreter: the graph flavor links the
# "blonde" graphics archive (no automatic standard I/O window) and hosts
# the interpreted program's standard files in an openwin window.
#
echo ""
echo "**********************************************************************"
echo "Building source/pint (graphics flavor) as pintg..."
echo "**********************************************************************"
echo ""
pc source/pint -mp=source/graph -r $OPTIONS
if [ $? -ne 0 ]; then

   echo "*** Error: compile failed"
   exit 1

fi
cp source/pint bin/pintg
pc source/pint -r $OPTIONS
if [ $? -ne 0 ]; then

   echo "*** Error: compile failed"
   exit 1

fi
cp source/pint bin
compprog source/pmach
#
# pmacht and pmachg are the same source built with the terminal and graphics
# module flavors first on the module path, mirroring pintt and pintg. The plain
# interpreter is rebuilt afterward so source/pmach matches its instruction file.
#
echo ""
echo "**********************************************************************"
echo "Building source/pmach (terminal flavor) as pmacht..."
echo "**********************************************************************"
echo ""
pc source/pmach -mp=source/term -r $OPTIONS
if [ $? -ne 0 ]; then

   echo "*** Error: compile failed"
   exit 1

fi
cp source/pmach bin/pmacht
echo ""
echo "**********************************************************************"
echo "Building source/pmach (graphics flavor) as pmachg..."
echo "**********************************************************************"
echo ""
pc source/pmach -mp=source/graph -r $OPTIONS
if [ $? -ne 0 ]; then

   echo "*** Error: compile failed"
   exit 1

fi
cp source/pmach bin/pmachg
pc source/pmach -r $OPTIONS
if [ $? -ne 0 ]; then

   echo "*** Error: compile failed"
   exit 1

fi
cp source/pmach bin

#
# cmacht is the terminal flavor of cmach, the same cmach.c built with -DTERMINAL
# so it hosts the terminal model too (mirroring pmacht). Built by the Makefile.
#
echo ""
echo "**********************************************************************"
echo "Building cmach terminal flavor as cmacht..."
echo "**********************************************************************"
echo ""
make bin/cmacht
if [ $? -ne 0 ]; then echo "*** Error: cmacht build failed"; exit 1; fi

#
# cmachg is the graphics flavor of cmach, the same cmach.c built with -DGRAPHICS.
# It hosts an Ami graphics window over the interpreted program (mirroring pmachg),
# linking the "blonde" NOSTDWIN graphics archive so the interpreter keeps its own
# console and vmhost opens the program's window. Built by the Makefile.
#
echo ""
echo "**********************************************************************"
echo "Building cmach graphics flavor as cmachg..."
echo "**********************************************************************"
echo ""
make bin/cmachg
if [ $? -ne 0 ]; then echo "*** Error: cmachg build failed"; exit 1; fi
