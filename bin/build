#!/bin/bash
#
# General build script for Pascal-P6
#
# Form:
# 
# build [<options for make>] [<options for pc>]
#
# Note: if you want to give multiple options for make or pc, surround in quotes
# like:
#
# build "-Bi" "-r -d"
#
function compprog {

   echo ""
   echo "**********************************************************************"
   echo "Building $1..."
   echo "**********************************************************************"
   echo ""
   pc $1 $OPTIONS
   if [ $? -ne 0 ]; then

      echo "*** Error: compile failed"
      exit 1

   fi
   cp $1 bin

}

OPTIONS=$2

make clean
make $1
if [ $? -ne 0 ]; then

   echo "*** Error: make failed"
   exit 1

fi

#
# Build dummy decks to satisfy pc builds.
#
echo ""
echo "**********************************************************************"
echo "Building Dummy decks..."
echo "**********************************************************************"
echo ""
pc libs/source/services -pint -r
cp libs/source/services.p6 libs
pc libs/source/terminal -pint -r
cp libs/source/terminal.p6 libs
pc libs/source/graphics -pint -r
cp libs/source/graphics.p6 libs
pc libs/source/sound -pint -r
cp libs/source/sound.p6 libs
pc libs/source/network -pint -r
cp libs/source/network.p6 libs

#
# General library modules in Pascaline.
# These are compiled to objects and intermediates both because they can be used
# in executables and interpretation.
#
echo ""
echo "**********************************************************************"
echo "Building Strings..."
echo "**********************************************************************"
echo ""
pc libs/source/strings -r
cp libs/source/strings.o libs
pc libs/source/strings -pint -r
cp libs/source/strings.p6 libs

echo ""
echo "**********************************************************************"
echo "Building Parse..."
echo "*******************************************s***************************"
echo ""
pc libs/source/parse -r
cp libs/source/parse.o libs
pc libs/source/parse -pint -r
cp libs/source/parse.p6 libs

#
# Programs in Pascaline.
#
compprog pc/pc
compprog pc/hashtabr
compprog pc/hashtabs
compprog source/genobj
#
# Test programs in libs/tests: build each as a native executable and place it
# in bin. pc detects each program's modules (graphics, sound, network,
# terminal, services) and links the matching libraries, so windowed, sound and
# network tests build the same way. Adding a new test to libs/tests is picked
# up here automatically.
#
for testprog in libs/tests/*.pas; do
   compprog "${testprog%.pas}"
done
#
# pgen and pcom must be a matched set
#
cp bin/pgen pgen.old
compprog source/pgen/amd64/pgen
cp source/pgen/amd64/pgen bin/pgen_amd64
cp bin/pgen pgen.new
cp pgen.old bin/pgen
compprog source/pcom
#
# Now regular
#
cp pgen.new bin/pgen
compprog source/pint
#
# pintt is the same source built with the terminal module flavor first on
# the module path (the instruction file appends the plain flavor after it).
# The plain interpreter is rebuilt afterward so source/pint matches its
# instruction file.
#
echo ""
echo "**********************************************************************"
echo "Building source/pint (terminal flavor) as pintt..."
echo "**********************************************************************"
echo ""
pc source/pint -mp=source/term -r $OPTIONS
if [ $? -ne 0 ]; then

   echo "*** Error: compile failed"
   exit 1

fi
cp source/pint bin/pintt
#
# pintg is the graphics-hosted interpreter: the graph flavor links the
# "blonde" graphics archive (no automatic standard I/O window) and hosts
# the interpreted program's standard files in an openwin window.
#
echo ""
echo "**********************************************************************"
echo "Building source/pint (graphics flavor) as pintg..."
echo "**********************************************************************"
echo ""
pc source/pint -mp=source/graph -r $OPTIONS
if [ $? -ne 0 ]; then

   echo "*** Error: compile failed"
   exit 1

fi
cp source/pint bin/pintg
pc source/pint -r $OPTIONS
if [ $? -ne 0 ]; then

   echo "*** Error: compile failed"
   exit 1

fi
cp source/pint bin
compprog source/pmach
