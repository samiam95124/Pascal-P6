#!/bin/bash
#
# Script to run a pcom self compile
#
# When REGRESS_OUT is set (a parallel per-model regress run), all generated
# files (the cpp'd source, intermediate, .org/.out/.lst/.dif and the tmp deck)
# go to that per-model directory; the pcom.pas source is read canonically. When
# unset, everything stays under source/ as before.
#
if [ -n "$REGRESS_OUT" ]; then tmpd="$REGRESS_OUT/"
else tmpd=""; fi
ob() { if [ -n "$REGRESS_OUT" ]; then echo "$REGRESS_OUT/$(basename "$1")"; else echo "$1"; fi; }

#
# First, change elide patterns to #ove prr file statements.
# The modified file goes in pcom.mpp.pas (pcom modified).
#
cpp -DSELF_COMPILE -DWRDSIZ64 -P -nostdinc -traditional-cpp source/pcom.pas $(ob source/pcom.mpp).pas
#
# Compile pcom to intermediate code using its binary version.
#
echo Compiling pcom to intermediate code
compile $1 $(ob source/pcom.mpp)
if [ $? -ne 0 ]
then

    echo "*** Compile failed"
    cat $(ob source/pcom.mpp).err
    exit 1

fi

#
# Now run that code on the interpreter and have it compile itself
# to intermediate again.
#
echo Running pcom to compile itself

cat $(ob source/pcom.mpp).p6 $(ob source/pcom.mpp).pas > ${tmpd}tmp.p6
mv $(ob source/pcom.mpp).p6 $(ob source/pcom.mpp).p6.org
cp ${tmpd}tmp.p6 $(ob source/pcom.mpp).p6
echo > $(ob source/pcom.mpp).inp

run $1 $(ob source/pcom.mpp)
cat $(ob source/pcom.mpp).lst
#
# Now we have the original intermediate from the binary version
# of pcom, and the intermediate generated by the interpreted
# pcom. Compare them for equality. Put the result in pcom.mpp.dif.
#
echo -n "Comparing the intermediate code for the runs ... "
diffnole $(ob source/pcom.mpp).p6.org $(ob source/pcom.mpp).out > $(ob source/pcom.mpp).dif
#
# Show the file, so if the length is zero, it compared ok.
#
#echo Resulting diff file length should be zero for pass
if test -s $(ob source/pcom.mpp).dif
then
    echo FAILED
else
    echo PASS
fi
echo
#ls -l source/pcom.mpp.dif
