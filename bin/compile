#!/bin/bash
#
# Compile a file in batch mode, as a thin wrapper over the pc build driver.
#
# Execution:
#
# compile [<options>] <file>
#
# <file> is the filename without extension. Compiles <file>.pas, producing the
# intermediate <file>.p6 and the error/listing output <file>.err, plus the
# per-mode products (the machine deck <file>.p6o, assembly/object files, and the
# executable). This does not run the program.
#
# When REGRESS_OUT is set, all generated products and the .err are placed in
# that directory (via pc -buildpath / -errfile) so models can build in parallel;
# the source is still read from its own path.
#
# The flags are one of:
#
# --pint     Generate the intermediate only (to be run via pint).
# --pmach    Generate the machine deck (to be run via pmach).
# --cmach    Generate the machine deck (to be run via cmach).
# --package  Generate a unified executable (mach code plus interpreter).
# --pgen     Generate a native executable for the current machine (default).
# --noerrmsg Do not echo the .err file on completion (the file is still written).
# --iso7185  Compile in ISO 7185 standard mode.
#
# All other options are passed through to the compiler.
#

mode=pgen
noerrmsg=0
listing=0
prog=""
pcflags=""

for param in "$@"
do

    case "$param" in

        --pint)     mode=pint ;;
        --pmach)    mode=pmach ;;
        --cmach)    mode=cmach ;;
        --package)  mode=package ;;
        --pgen)     mode=pgen ;;
        --noerrmsg) noerrmsg=1 ;;
        --iso7185)  pcflags="$pcflags -iso7185" ;;
        --list+|--list) listing=1 ;;  # listing on; redirected via --list= below
        --list-)    listing=0 ;;       # listing off; errors-only via -ef= below
        -*)         pcflags="$pcflags $param" ;;  # pass other options through
        *)          prog="$param" ;;

    esac

done

if [ -z "$prog" ]; then

    echo "*** Error: No compile file specified"
    exit 1

fi

#
# Output location: a REGRESS_OUT directory (for parallel per-model builds) or,
# by default, alongside the source. pc reads the source in place and writes the
# generated products and the .err to the build path.
#
if [ -n "$REGRESS_OUT" ]; then

    buildpath="-bp=$REGRESS_OUT"
    err="$REGRESS_OUT/$(basename "$prog").err"

else

    buildpath=""
    err="$prog.err"

fi

#
# Direct the compiler output to the .err file. When a listing was requested,
# --list=<file> captures the full source listing (with inline error markers and
# the error summary); otherwise -ef=<file> captures errors only. In both cases
# there is no signon banner; strip removes the banner from the goldens.
#
if [ "$listing" = "1" ]; then
    errflag="--list=$err"
else
    errflag="-ef=$err"
fi

rm -f "$err" # clear any prior .err so a build that emits nothing is detectable
# pc's driver chatter (signon, "Build has errors") goes to the terminal; the
# real compiler output is in the .err, so silence it for a clean batch run.
pc -$mode $buildpath "$errflag" $pcflags "$prog" >/dev/null 2>&1
status=$?

#
# Fallback for deviance tests: pc pre-scans the source to identify the program
# and its modules before building. A program whose deliberate syntax error
# defeats that scan (e.g. a missing "program" word-symbol, or a malformed token)
# leaves pc with nothing to build and no .err. Such a file is a single
# self-contained unit, so compile it directly with pcom -- as the classic
# compile did -- writing the same products to the build path.
#
if [ ! -f "$err" ]; then

    if [ -n "$REGRESS_OUT" ]; then
        p6out="$REGRESS_OUT/$(basename "$prog").p6"
    else
        p6out="$prog.p6"
    fi
    pcom "$prog.pas" "$p6out" "$errflag" $pcflags >/dev/null 2>&1
    status=$?

fi

#
# pc and pcom can exit zero on a compile error when output is directed to a
# list/error file, so treat a non-zero error count in the .err as failure. This
# stops callers (testprog) from trying to run a program that did not compile.
#
if [ -f "$err" ] && grep -q "Errors in program: [1-9]" "$err"; then

    status=1

fi

#
# Echo the compiler error/listing output unless suppressed.
#
if [ "$noerrmsg" = "0" ] && [ -f "$err" ]; then

    cat "$err"

fi

exit $status
