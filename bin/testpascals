#!/bin/bash
#
# Script to test pascal-s compile and run
#
# When REGRESS_OUT is set (a parallel per-model regress run), all generated
# files go to that per-model directory; inputs (the .pas/.cmp) are read from
# sample_programs/. When unset, everything stays in sample_programs/ as before.
#
if [ -n "$REGRESS_OUT" ]; then tmpd="$REGRESS_OUT/"; incd="$REGRESS_OUT"
else tmpd=""; incd="."; fi
ob() { if [ -n "$REGRESS_OUT" ]; then echo "$REGRESS_OUT/$(basename "$1")"; else echo "$1"; fi; }

#
# Compile pascals. The single intermediate is reused for every backend; the
# native (pgen) path needs it compiled with the SysV ABI flag.
#
amdopt=""
if [ "$1" = "--pgen" ]; then amdopt="--amd64_sysv"; fi
echo "Compiling pascals to intermediate code"
compile --list- $1 $amdopt sample_programs/pascals
cat $(ob sample_programs/pascals).err
#
# Create null input file
#
echo > ${tmpd}pascals.inp
#
# Now run pascals on pint, which runs the test program.
#
if [ "$1" = "--pmach" ]; then

    pint $(ob sample_programs/pascals).p6 $(ob sample_programs/pascals).p6o --machdeck
    pmach $(ob sample_programs/pascals).p6o ${tmpd}temp sample_programs/roman.pas ${tmpd}temp2 < ${tmpd}pascals.inp > $(ob sample_programs/pascals).lst

elif [ "$1" = "--cmach" ]; then

    pint $(ob sample_programs/pascals).p6 $(ob sample_programs/pascals).p6o --machdeck
    cmach $(ob sample_programs/pascals).p6o sample_programs/roman.pas ${tmpd}temp < ${tmpd}pascals.inp > $(ob sample_programs/pascals).lst

elif [ "$1" = "--package" ]; then

    pint $(ob sample_programs/pascals).p6 $(ob sample_programs/pascals).p6o --machdeck
    genobj $(ob sample_programs/pascals).p6o ${tmpd}program_code.c
	gcc -DPACKAGE -DWRDSIZ64 -DGPC=0 -I$incd -o $(ob sample_programs/pascals) $PASCALP6/source/cmach/cmach.c -lm
	$(ob sample_programs/pascals) sample_programs/roman.pas ${tmpd}temp $options < ${tmpd}pascals.inp > $(ob sample_programs/pascals).lst

elif [ "$1" = "--pgen" ]; then

    pgen $(ob sample_programs/pascals).p6 $(ob sample_programs/pascals).s
    gcc -g3 -DWRDSIZ64 $PASCALP6/source/pgen/psystem.c \
        -x assembler $PASCALP6/source/pgen/amd64/psystem.asm \
        $PASCALP6/source/pgen/amd64/main.asm $(ob sample_programs/pascals).s -o $(ob sample_programs/pascals) -lm
	$(ob sample_programs/pascals) sample_programs/roman.pas ${tmpd}temp $options < ${tmpd}pascals.inp > $(ob sample_programs/pascals).lst

else

    pint $(ob sample_programs/pascals).p6 ${tmpd}temp sample_programs/roman.pas < ${tmpd}pascals.inp > $(ob sample_programs/pascals).lst

fi
#
# Now compare with reference
#
echo Comparing PAT result to reference
strip $(ob sample_programs/pascals).lst ${tmpd}tmp1
strip sample_programs/pascals.cmp ${tmpd}tmp2
diff -B ${tmpd}tmp1 ${tmpd}tmp2 > $(ob sample_programs/pascals).dif
rm -f ${tmpd}tmp1
rm -f ${tmpd}tmp2
ls -l $(ob sample_programs/pascals).dif > ${tmpd}tmp1
grep ".dif" ${tmpd}tmp1
rm -f ${tmpd}tmp1
## pass if diff file is empty
if test -s $(ob sample_programs/pascals).dif
then
    echo "*** FAIL"
    exit 1
else
    echo "PASS"
fi
