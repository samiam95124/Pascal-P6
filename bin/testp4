#!/bin/bash
#
# Script to test p4 compile and run
#
# When REGRESS_OUT is set (a parallel per-model regress run), all generated
# files go to that per-model directory; inputs (the .pas/.cmp) are read from
# p4/. When unset, everything stays in p4/ as before.
#
if [ -n "$REGRESS_OUT" ]; then tmpd="$REGRESS_OUT/"; incd="$REGRESS_OUT"
else tmpd=""; incd="."; fi
ob() { if [ -n "$REGRESS_OUT" ]; then echo "$REGRESS_OUT/$(basename "$1")"; else echo "$1"; fi; }

#
# Compile p4. The single intermediate is reused for every backend; the native
# (pgen) path needs it compiled with the SysV ABI flag.
#
amdopt=""
if [ "$1" = "--pgen" ]; then amdopt="--amd64_sysv"; fi
echo "Compiling pcom to intermediate code"
compile --out="$REGRESS_OUT" --list- $1 $amdopt p4/pcom
cat $(ob p4/pcom).err
#
# Run the p4 compiler to get p4 intermediate
#
if [ "$1" = "--pgen" ]; then
    $(ob p4/pcom) $(ob p4/standardp).p4 < p4/standardp.pas
else
    pint $(ob p4/pcom).p6 ${tmpd}temp $(ob p4/standardp).p4 < p4/standardp.pas
fi
#
# Compile pint
#
echo Compiling pint to intermediate code
compile --out="$REGRESS_OUT" --list- $1 $amdopt p4/pint
#
# Create null input file
#
echo > ${tmpd}pint.inp
#
# Now run pint(p4) on pint(p6), which runs the test program.
#
if [ "$1" = "--pmach" ]; then

    echo "Executing with pmach..."
    pint $(ob p4/pint).p6 $(ob p4/pint).p6o --machdeck
    pmach $(ob p4/pint).p6o ${tmpd}temp $(ob p4/standardp).p4 ${tmpd}temp1 < ${tmpd}pint.inp > $(ob p4/standardp).lst

elif [ "$1" = "--cmach" ]; then

    echo "Executing with cmach..."
    pint $(ob p4/pint).p6 $(ob p4/pint).p6o --machdeck
    cmach $(ob p4/pint).p6o $(ob p4/standardp).p4 ${tmpd}temp < ${tmpd}pint.inp > $(ob p4/standardp).lst

elif [ "$1" = "--package" ]; then

    echo "Executing with package..."
    pint $(ob p4/pint).p6 $(ob p4/pint).p6o --machdeck
    genobj $(ob p4/pint).p6o ${tmpd}program_code.c
	gcc -DPACKAGE -DWRDSIZ64 -DGPC=0 -I$incd -o $(ob p4/pint) $PASCALP6/source/cmach/cmach.c -lm
	$(ob p4/pint) $(ob p4/standardp).p4 ${tmpd}temp $options < ${tmpd}pint.inp > $(ob p4/standardp).lst

elif [ "$1" = "--pgen" ]; then

    echo "Executing with pgen..."
    pgen $(ob p4/pint).p6 $(ob p4/pint).s
    gcc -g3 -DWRDSIZ64 $PASCALP6/source/pgen/psystem.c \
        -x assembler $PASCALP6/source/pgen/amd64/psystem.asm \
        $PASCALP6/source/pgen/amd64/main.asm $(ob p4/pint).s -o $(ob p4/pint) -lm
	$(ob p4/pint) $(ob p4/standardp).p4 ${tmpd}temp $options < ${tmpd}pint.inp > $(ob p4/standardp).lst

else

    echo "Executing with pint..."
    pint $(ob p4/pint).p6 ${tmpd}temp $(ob p4/standardp).p4 ${tmpd}temp4 < ${tmpd}pint.inp > $(ob p4/standardp).lst

fi
#
# Now compare with reference
#
echo Comparing PAT result to reference
strip $(ob p4/standardp).lst ${tmpd}tmp1
if [ "$1" = "--cmach" ] || [ "$1" = "--package" ] || [ "$1" = "--pgen" ]; then

    strip p4/standardpc.cmp ${tmpd}tmp2

else

    strip p4/standardp.cmp ${tmpd}tmp2

fi
diff -B ${tmpd}tmp1 ${tmpd}tmp2 > $(ob p4/standardp).dif
rm -f ${tmpd}tmp1
rm -f ${tmpd}tmp2
ls -l $(ob p4/standardp).dif > ${tmpd}tmp1
grep ".dif" ${tmpd}tmp1
rm -f ${tmpd}tmp1
## pass if diff file is empty
if test -s $(ob p4/standardp).dif
then
    echo "*** FAIL"
    exit 1
else
    echo "PASS"
fi

rm -f ${tmpd}pcom.inp
rm -f ${tmpd}pint.inp
