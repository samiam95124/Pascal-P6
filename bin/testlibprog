#!/bin/bash
#
# Test a libs/tests module-using program against a gold standard
#
# Execution:
#
# testlibprog [--pint|--pmach|--cmach|--pgen] <name>
#
# Compiles and runs libs/tests/<name> for the selected model and compares its
# output to libs/tests/<name>.cmp (the gold standard), producing
# libs/tests/<name>.dif. These programs use library modules (services, strings,
# network, ...), so they are built with pc, which resolves the module path and
# links the native archives -- the obsolete compile/run scripts do not.
#
# Must be run from the project root (the programs reach their data files by
# paths relative to it, e.g. libs/source/strings_test.dat).
#
# The flags select the execution model:
#
# --pgen    Native code via pgen (the default).
# --pint    Interpret the P-code deck with pint.
# --pmach   Assemble a machine deck and run it with pmach.
# --cmach   Assemble a machine deck and run it with cmach (which hosts the Ami
#           externals, built through the Ami bypass stdio, like pmach).
# --package Build a self-contained package executable (machine deck embedded in
#           cmach) and run it; the package hosts the externals like cmach.
#

param1=$1
name=$2
if [ -z "$param1" ]; then param1="--pgen"; fi

if [ -z "$name" ]; then
   echo "*** testlibprog: no program name given"
   exit 1
fi

base="libs/tests/$name"

if [ ! -f "$base.pas" ]; then
   echo "*** testlibprog: $base.pas does not exist"
   exit 1
fi

#
# When REGRESS_OUT is set (a parallel per-model run), compile a copy of the
# source there so pc's products (.p6, .s, .o, exe) land in the per-model
# directory rather than the shared libs/tests. The program is still executed
# from the repo root, so its relative input paths (libs/source/<x>.dat,
# libs/services_test1, libs/tests/test_files/...) resolve. The gold .cmp is read
# from the source location. When unset, everything stays in libs/tests.
#
if [ -n "$REGRESS_OUT" ]; then
   mkdir -p "$REGRESS_OUT"
   ob="$REGRESS_OUT/$name"
   cp "$base.pas" "$ob.pas"
else
   ob="$base"
fi
rm -f "$ob.lst" "$ob.dif"

# absolute path runs directly; relative needs the ./ prefix
exe="$ob"; case "$ob" in /*) ;; *) exe="./$ob";; esac

if [ "$param1" = "--pgen" ]; then

   pc "$ob" -r > "$ob.err" 2>&1
   if [ $? -ne 0 ]; then echo "*** testlibprog: $name compile failed"; exit 1; fi
   "$exe" > "$ob.lst" 2>/dev/null

elif [ "$param1" = "--pint" ]; then

   pc "$ob" -pint -r > "$ob.err" 2>&1
   if [ $? -ne 0 ]; then echo "*** testlibprog: $name compile failed"; exit 1; fi
   pint "$ob.p6" > "$ob.lst" 2>/dev/null

elif [ "$param1" = "--pmach" ]; then

   pc "$ob" -pint -r > "$ob.err" 2>&1
   if [ $? -ne 0 ]; then echo "*** testlibprog: $name compile failed"; exit 1; fi
   pint "$ob.p6" "$ob.p6o" --machdeck > /dev/null 2>&1
   pmach "$ob.p6o" > "$ob.lst" 2>/dev/null

elif [ "$param1" = "--cmach" ]; then

   # cmach hosts the services/sound/network externals (built with the Ami bypass
   # stdio, like pmach), so the library tests run under it like pmach: compile,
   # dump the machine deck, interpret it.
   pc "$ob" -pint -r > "$ob.err" 2>&1
   if [ $? -ne 0 ]; then echo "*** testlibprog: $name compile failed"; exit 1; fi
   pint "$ob.p6" "$ob.p6o" --machdeck > /dev/null 2>&1
   cmach "$ob.p6o" > "$ob.lst" 2>/dev/null

elif [ "$param1" = "--package" ]; then

   # package: a self-contained executable with the machine deck embedded in
   # cmach, so it hosts the Ami externals like cmach. Build and run it like the
   # pgen native case.
   pc "$ob" -package -r > "$ob.err" 2>&1
   if [ $? -ne 0 ]; then echo "*** testlibprog: $name compile failed"; exit 1; fi
   "$exe" > "$ob.lst" 2>/dev/null

else

   echo "*** testlibprog: unrecognized model $param1"
   exit 1

fi

if [ ! -f "$base.cmp" ]; then
   echo "*** testlibprog: gold file $base.cmp does not exist"
   exit 1
fi

# Compare to the gold standard with the Pascaline dif tool (it handles both
# line endings transparently, so no flip is needed; strip removes the
# interpreter banner first, as testprog does). services_test masks its
# run-varying time/date fields with the dif '?' wildcard, so it compares with
# "dif -q"; the other tests compare with "dif -w" (ignore whitespace), under
# which any literal '?' in a gold file stays literal.
strip "$ob.lst" "$ob.lst.s"
strip "$base.cmp" "$ob.cmp.s"
if [ "$name" = "services_test" ]; then
   dif -q "$ob.lst.s" "$ob.cmp.s" > "$ob.dif"
else
   dif -w "$ob.lst.s" "$ob.cmp.s" > "$ob.dif"
fi
rm -f "$ob.lst.s" "$ob.cmp.s"
wc -l "$ob.dif"
