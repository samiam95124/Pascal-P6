#!/bin/bash
#
#
# Run rejection tests
#
# The rejection tests use the same format as the acceptance tests, but there
# is no positive go/no go indication for them. Each test should generate a
# failure, and all you can say is that the test has failed if there were no
# error(s).
#

error=0

function dotestprog {

    testprog --list+ --lineinfo- $1 $3 --noerrmsg $2
    if [ $? -ne 0 ]
    then

        error=1

    fi

}

echo Running tests

option="$1"
if [ "$1" = "" ]; then

    option="--pint"

fi

#
# The per-test products (each iso7185prtNNNN.err/.lst/.dif) are written by
# testprog. When REGRESS_OUT is set (a parallel per-model run) they, the
# aggregate listing, and the temps go to that per-model directory ($rd); inputs
# (.pas/.cmp/.ecp) are read from standard_tests ($sd). When unset, everything
# stays in standard_tests.
#
sd="standard_tests"
if [ -n "$REGRESS_OUT" ]; then rd="$REGRESS_OUT"; tmpd="$REGRESS_OUT/"
else rd="standard_tests"; tmpd=""; fi

#
# Note some of the tests need options to run.
#
dotestprog $option standard_tests/iso7185prt0001
dotestprog $option standard_tests/iso7185prt0002
