dotestprog $option standard_tests/iso7185prt1900
dotestprog $option standard_tests/iso7185prt1901
dotestprog $option standard_tests/iso7185prt1902
dotestprog $option standard_tests/iso7185prt1903
dotestprog $option standard_tests/iso7185prt1904
dotestprog $option standard_tests/iso7185prt1905
dotestprog $option standard_tests/iso7185prt1906
dotestprog $option standard_tests/iso7185prt1907a
dotestprog $option standard_tests/iso7185prt1907b
dotestprog $option standard_tests/iso7185prt1908
dotestprog $option standard_tests/iso7185prt1909
dotestprog $option standard_tests/iso7185prt1911
dotestprog $option standard_tests/iso7185prt1912
dotestprog $option standard_tests/iso7185prt1913
dotestprog $option standard_tests/iso7185prt1914
dotestprog $option standard_tests/iso7185prt1915
dotestprog $option standard_tests/iso7185prt1916
dotestprog $option standard_tests/iso7185prt1917
dotestprog $option standard_tests/iso7185prt1918

echo Creating combined listing
echo "*******************************************************************************" > $rd/iso7185prt.lst
echo >> $rd/iso7185prt.lst
echo "Pascal Rejection test run for iso7185prt" >> $rd/iso7185prt.lst
echo >> $rd/iso7185prt.lst
echo "*******************************************************************************" >> $rd/iso7185prt.lst
#
# Make a list of files WITHOUT compile errors
#
echo "Creating error accounting listings"
grep -l "Errors in program: 0" $rd/iso7185prt*.err > $rd/iso7185prt.nocerr
#
# Make a list of files WITHOUT runtime errors. This is probably p5c specific.
#
grep -L "\*\*\*" $rd/iso7185prt*.lst > $rd/iso7185prt.norerr
#
# Find files with NO errors either at compile time or runtime. This is done
# by concatenating the files, sorting and finding duplicate filenames. The
# uniq -d -w 30 relies on the "standard_tests/" prefix (15 chars) padding the
# name so the differing .err/.lst extension lands past column 30 and the two
# siblings dedup. Rewrite the real product path to the canonical $sd prefix so
# this works wherever the products live, and matches the gold listing.
#
cat $rd/iso7185prt.nocerr $rd/iso7185prt.norerr | sed "s#.*/#$sd/#" > ${tmpd}temp
sort ${tmpd}temp | uniq -d -w 30 > $rd/iso7185prt.noerr
#
# Place in combined listing as report
#
echo >> $rd/iso7185prt.lst
echo "Tests for which no compile or runtime error was flagged: **********************" >> $rd/iso7185prt.lst
echo >> $rd/iso7185prt.lst
cat $rd/iso7185prt.noerr >> $rd/iso7185prt.lst

#
# Make a listing of compiler output difference files to look at. The .err
# products live in $rd; the blessed .ecp inputs in $sd.
#
echo creating compile time difference list
echo > $rd/iso7185prt.ecdlst
for a in `basename --suffix=.err $rd/iso7185prt*.err` ; do
    diffnolestrip $rd/$a.err $sd/$a.ecp > $rd/$a.ecd
    if [ -s $rd/$a.ecd ] ; then
        echo "*** compare $sd/$a.err failed" >> $rd/iso7185prt.ecdlst
        error=1
    else
        echo "    compare $sd/$a.err OK" >> $rd/iso7185prt.ecdlst
    fi
done

#
# Place in combined listing
#
echo >> $rd/iso7185prt.lst
echo "Compile output differences: **********************" >> $rd/iso7185prt.lst
echo >> $rd/iso7185prt.lst
cat $rd/iso7185prt.ecdlst >> $rd/iso7185prt.lst

#
# Make a listing of run output difference files to look at. The .dif products
# live in $rd.
#
echo creating runtime difference list
echo > $rd/iso7185prt.diflst
for f in `basename --suffix=.dif $rd/iso7185prt????.dif` ; do
    if [ -s $rd/$f.dif ] ; then
        echo "*** run $sd/$f.dif failed" >> $rd/iso7185prt.diflst
        error=1
    else
        echo "    run $sd/$f.dif OK" >> $rd/iso7185prt.diflst
    fi
done

#
# Place in combined listing
#
echo >> $rd/iso7185prt.lst
echo "Run output differences: **********************" >> $rd/iso7185prt.lst
echo >> $rd/iso7185prt.lst
cat $rd/iso7185prt.diflst >> $rd/iso7185prt.lst

#
# Add individual program compiles and runs. The .pas sources are the inputs in
# $sd; their .err/.lst products live in $rd.
#
echo Adding program compile and runs
echo >> $rd/iso7185prt.lst
echo "*******************************************************************************" >> $rd/iso7185prt.lst
echo >> $rd/iso7185prt.lst
echo "Listings for compile and run of iso7185prt" >> $rd/iso7185prt.lst
echo >> $rd/iso7185prt.lst
echo "*******************************************************************************" >> $rd/iso7185prt.lst

for f in $sd/iso7185prt*.pas ; do

    b=`basename $f .pas`
    echo >> $rd/iso7185prt.lst
    echo "Listing for $sd/$f *************************************" >> $rd/iso7185prt.lst
    echo >> $rd/iso7185prt.lst
    echo Compile: >> $rd/iso7185prt.lst
    echo >> $rd/iso7185prt.lst
    cat $rd/$b.err >> $rd/iso7185prt.lst
    echo >> $rd/iso7185prt.lst
    if [ -e "$rd/$b.lst" ] ; then

        echo Run: >> $rd/iso7185prt.lst
        echo >> $rd/iso7185prt.lst
        cat $rd/$b.lst >> $rd/iso7185prt.lst

    fi

done

#
# Strip compiler specific messages out and compare the entire listing
#
strip $rd/iso7185prt.lst ${tmpd}tmp1
if [ "$option" = "--pgen" ]; then

    strip $sd/iso7185prt_pgen.cmp ${tmpd}tmp2
    diff -Bw ${tmpd}tmp1 ${tmpd}tmp2 > $rd/iso7185prt.dif
    wc -l $rd/iso7185prt.dif

else

    strip $sd/iso7185prt.cmp ${tmpd}tmp2
    diff -Bw ${tmpd}tmp1 ${tmpd}tmp2 > $rd/iso7185prt.dif
    wc -l $rd/iso7185prt.dif

fi
rm -f ${tmpd}tmp1 ${tmpd}tmp2

#exit $error
exit
