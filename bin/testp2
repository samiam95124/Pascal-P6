#!/bin/bash
#
# Script to test p2 compile and run
#
# When REGRESS_OUT is set (a parallel per-model regress run), all generated
# files (the compiled P2 compiler, the roman.p2 intermediate, the .lst/.dif and
# the shared temps) go to that per-model directory; inputs (the .pas/.cmp) are
# read from p2/. When unset, everything stays in p2/ as before.
#
if [ -n "$REGRESS_OUT" ]; then tmpd="$REGRESS_OUT/"; incd="$REGRESS_OUT"
else tmpd=""; incd="."; fi
ob() { if [ -n "$REGRESS_OUT" ]; then echo "$REGRESS_OUT/$(basename "$1")"; else echo "$1"; fi; }

#
# Compile P2
#
echo "Compiling pcomp to intermediate code"
compile --list- $1 p2/pcomp
cat $(ob p2/pcomp).err
#
# Run the p2 compiler to get p2 intermediate
#
# Note temp is unused (prr out), and roman.p2 is read from the command line
# at the second level.
#
if [ "$1" = "--pgen" ]; then
    $(ob p2/pcomp) $(ob p2/roman).p2 < p2/roman.pas
else
    pint $(ob p2/pcomp).p6 ${tmpd}temp $(ob p2/roman).p2 < p2/roman.pas
fi
#
# Compile pasint to intermediate code
#
echo Compiling pasint to intermediate
compile --list- --reference- $1 p2/pasint
cat $(ob p2/pasint).err
#
# Create null input file
#
echo > ${tmpd}pasint.inp
#
# Now run pasint on pint, which runs the test program.
#
# Note that temp is unused (prr out), and roman.p2 and temp2 are read from the
# command line at level 2. temp2 is unused (prr out, second level).
#
if [ "$1" = "--pmach" ]; then

    pint $(ob p2/pasint).p6 $(ob p2/pasint).p6o --machdeck
    pmach $(ob p2/pasint).p6o ${tmpd}temp $(ob p2/roman).p2 ${tmpd}temp2 < ${tmpd}pasint.inp > $(ob p2/roman).lst

elif [ "$1" = "--cmach" ]; then

    pint $(ob p2/pasint).p6 $(ob p2/pasint).p6o --machdeck
    cmach $(ob p2/pasint).p6o $(ob p2/roman).p2 ${tmpd}temp < ${tmpd}pasint.inp > $(ob p2/roman).lst

elif [ "$1" = "--package" ]; then

    pint $(ob p2/pasint).p6 $(ob p2/pasint).p6o --machdeck
    genobj $(ob p2/pasint).p6o ${tmpd}program_code.c
	gcc -DPACKAGE -DWRDSIZ64 -DGPC=0 -I$incd -o $(ob p2/pasint) $PASCALP6/source/cmach/cmach.c -lm
	$(ob p2/pasint) $(ob p2/roman).p2 ${tmpd}temp $options < ${tmpd}pasint.inp > $(ob p2/roman).lst

elif [ "$1" = "--pgen" ]; then

    pgen $(ob p2/pasint).p6 $(ob p2/pasint).s
    gcc -g3 -DWRDSIZ64 $PASCALP6/source/pgen/psystem.c \
        -x assembler $PASCALP6/source/pgen/amd64/psystem.asm \
        $PASCALP6/source/pgen/amd64/main.asm $(ob p2/pasint).s -o $(ob p2/pasint) -lm
	$(ob p2/pasint) $(ob p2/roman).p2 ${tmpd}temp $options < ${tmpd}pasint.inp > $(ob p2/roman).lst

else

    pint $(ob p2/pasint).p6 ${tmpd}temp $(ob p2/roman).p2 ${tmpd}temp2 < ${tmpd}pasint.inp > $(ob p2/roman).lst

fi
#
# Now compare with reference
#
echo Comparing PAT result to reference
strip $(ob p2/roman).lst ${tmpd}tmp1
strip p2/roman.cmp ${tmpd}tmp2
diff -B ${tmpd}tmp1 ${tmpd}tmp2 > $(ob p2/roman).dif
rm -f ${tmpd}tmp1
rm -f ${tmpd}tmp2
ls -l $(ob p2/roman).dif > ${tmpd}tmp1
grep ".dif" ${tmpd}tmp1
rm -f ${tmpd}tmp1
## pass if diff file is empty
if test -s $(ob p2/roman).dif
then
    echo "*** FAIL"
    exit 1
else
    echo "PASS"
fi
