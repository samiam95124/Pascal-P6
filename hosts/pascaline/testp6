#!/bin/bash
#
# Script to test p6 compile and run
#
# 48 minutes on AMD Ryzen 9 3950x 16-core processorx32
#
# When REGRESS_OUT is set (a parallel per-model regress run), all generated
# files (the cpp'd sources, intermediates, objects, executable, .lst/.dif and
# the temps) go to that per-model directory; inputs (the .pas sources and the
# .cmp gold) are read from their canonical locations. When unset, everything
# stays under source/ as before.
#
# Note: the original compared standard_tests/iso7185pat.lst (left by the earlier
# PAT test) rather than this run's own output -- a latent inconsistency. Under
# the redirect that stale file is not present, so the comparison now reads the
# listing this run actually produced.
#
if [ -n "$REGRESS_OUT" ]; then tmpd="$REGRESS_OUT/"; incd="$REGRESS_OUT"
else tmpd=""; incd="."; fi
ob() { if [ -n "$REGRESS_OUT" ]; then echo "$REGRESS_OUT/$(basename "$1")"; else echo "$1"; fi; }

#
# Compile p6/pcom to p6 intermediate
#
echo "Compiling pcom to intermediate code"
cpp -DWRDSIZ64 -P -nostdinc -traditional-cpp source/pcom.pas $(ob source/pcom.mpp).pas
compile --out="$REGRESS_OUT" --list- $1 $(ob source/pcom.mpp)
cat $(ob source/pcom.mpp).err
#
# Run P6/pcom on P6/pint to compile iso7185pat to P6/intermediate
#
pint $(ob source/pcom.mpp).p6 ${tmpd}temp standard_tests/iso7185pat.pas $(ob source/iso7185pat).p6
#
# Compile pint
#
echo "Compiling pint to intermediate code"
cpp -DSHORT_STORE -DWRDSIZ64 -P -nostdinc -traditional-cpp source/pint.pas $(ob source/pint.mpp).pas
compile --out="$REGRESS_OUT" --list- $1 $(ob source/pint.mpp)
cat $(ob source/pint.mpp).err
#
# Create null input file
#
echo > $(ob source/pint).inp
#
# Now run pint(p6) on pint(p6), which runs the test program.
#
# Note that temp is unused (prr out), and standardp.p6 and temp2 are read from the
# command line at level 2. temp2 is unused (prr out, second level).
#
if [ "$1" = "--pmach" ]; then

    echo "Running pmach test..."
    pint $(ob source/pint.mpp).p6 $(ob source/pint).p6o --machdeck
    pmach $(ob source/pint).p6o ${tmpd}temp $(ob source/iso7185pat).p6 ${tmpd}temp1 < $(ob source/pint).inp > $(ob source/iso7185pat).lst

elif [ "$1" = "--cmach" ]; then

    echo "Running cmach test..."
    pint $(ob source/pint.mpp).p6 $(ob source/pint).p6o --machdeck
    cmach $(ob source/pint).p6o $(ob source/iso7185pat).p6 ${tmpd}temp < $(ob source/pint).inp > $(ob source/iso7185pat).lst

elif [ "$1" = "--package" ]; then

    echo "Running package test..."
    pint $(ob source/pint.mpp).p6 $(ob source/pint).p6o --machdeck
    genobj $(ob source/pint).p6o ${tmpd}program_code.c
	gcc -DPACKAGE -DWRDSIZ64 -DGPC=0 -o $(ob source/pint) $PASCALP6/source/cmach/cmach.c ${tmpd}program_code.c -lm
	pint $(ob source/iso7185pat).p6 ${tmpd}temp $options < $(ob source/pint).inp > $(ob source/iso7185pat).lst

elif [ "$1" = "--pgen" ]; then

    echo "Running pgen test..."
    pgen $(ob source/pint.mpp).p6 $(ob source/pint).s
    gcc -g3 -DWRDSIZ64 $PASCALP6/source/pgen/psystem.c \
        -x assembler $PASCALP6/source/pgen/amd64/psystem.asm \
        $PASCALP6/source/pgen/amd64/main.asm $(ob source/pint).s -o $(ob source/pint) -lm
	pint $(ob source/iso7185pat).p6 ${tmpd}temp $options < $(ob source/pint).inp > $(ob source/iso7185pat).lst

else

    echo "Running pint test..."
    pint $(ob source/pint.mpp).p6 ${tmpd}temp $(ob source/iso7185pat).p6 ${tmpd}temp2 \
        < $(ob source/pint).inp > $(ob source/iso7185pat).lst

fi
#
# Now compare with reference
#
echo "Comparing PAT result to reference"
strip $(ob source/iso7185pat).lst ${tmpd}tmp1
strip standard_tests/iso7185patp6c.cmp ${tmpd}tmp2
diff -B ${tmpd}tmp1 ${tmpd}tmp2 > $(ob standard_tests/iso7185pat).dif
rm -f ${tmpd}tmp1 ${tmpd}tmp2
ls -l $(ob standard_tests/iso7185pat).dif > ${tmpd}tmp1
grep ".dif" ${tmpd}tmp1
rm -f ${tmpd}tmp1
## pass if diff file is empty
if test -s $(ob standard_tests/iso7185pat).dif
then
    echo "*** FAIL"
    exit 1
else
    echo "PASS"
fi
