#!/bin/bash
#
# Compile and run with P6.
#
# Execute with:
#
# p6 [flags] [<sourcefile>]...
#
# Where <sourcefile> is the name of the source file without extension. The
# program is the last source file named; any modules it uses or joins are built
# automatically. Compiler errors are output to the screen. Input and output to
# and from the running program are from and to the console.
#
# The flags are one of:
#
# --pint     Run via pint, the interpreter (default).
# --pmach    Run the machine deck via pmach.
# --cmach    Run the machine deck via cmach.
# --package  Run the packaged application.
# --pgen     Run the native executable.
#
# All other options (listing, debug, -mp module path, etc.) are passed through
# to the pc build driver, which performs the actual compilation. The
# intermediate is placed in <prog>.p6, where <prog> is the program name. For
# pmach/cmach the machine deck is placed in <prog>.p6o; for pgen/package the
# final executable is placed under <prog>.
#

mode=pint
prog=""
pcflags=""

for param in "$@"
do

    case "$param" in

        --pint|-pint)       mode=pint ;;
        --pmach|-pmach)     mode=pmach ;;
        --cmach|-cmach)     mode=cmach ;;
        --package|-package) mode=package ;;
        --pgen|-pgen)       mode=pgen ;;

        -h|-help|--help)
            echo
            echo "Compile and run with P6 (wrapper over the pc build driver)."
            echo
            echo "Execute with:"
            echo
            echo "p6 [--pint|--pmach|--cmach|--package|--pgen] [options] [<sourcefile>]..."
            echo
            echo "The program is the last source file named; the modules it uses or"
            echo "joins are built automatically. Listing, debug and -mp module-path"
            echo "options are passed through to pc. Input and output to and from the"
            echo "running program are from and to the console."
            echo
            echo "The flags are one of:"
            echo
            echo "--pint    Run via pint, the interpreter (default)."
            echo "--pmach   Run the machine deck via pmach."
            echo "--cmach   Run the machine deck via cmach."
            echo "--package Run the packaged application."
            echo "--pgen    Run the native executable."
            echo
            exit 0 ;;

        -*) # any other option: pass through to pc
            pcflags="$pcflags $param" ;;

        *)  # source file: the program is the last one named
            prog="$param" ;;

    esac

done

if [ -z "$prog" ]; then

    echo "*** Error: No compile file specified"
    exit 1

fi

#
# Build the program and its modules with pc.
#
pc -$mode $pcflags "$prog" || exit 1

#
# Run the product through the selected backend.
#
case "$mode" in

    pmach)        pmach "$prog.p6o" "$prog.out" ;;
    cmach)        cmach "$prog.p6o" "$prog.out" ;;
    pgen|package) "./$prog" ;;
    *)            pint  "$prog.p6"  "$prog.out" ;;

esac
