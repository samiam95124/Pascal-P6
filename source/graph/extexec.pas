           a1 := getadr(params+adrsize+ptrsize); { handler frame }
           { only global-level handlers: nested ones need the
             planned thunk securing }
           if ad2 <> 0 then if a1 <> globalframe then
              errore(FunctionNotImplemented);
           a2 := getint(params+adrsize+ptrsize*2); { event code }
           putint(ad, vmhand[a2+1]);
           vmhand[a2+1] := ad2;
           if not hooked[a2+1] then begin

              graphics.eventover(cnvevtcod(a2), evtthunk, a3);
              hooked[a2+1] := true

           end;
           params := params+adrsize+ptrsize*2+intsize

       end;

       93: begin { eventsover }

           evtsetup;
           ad := getadr(params); { out oeh }
           ad2 := getadr(params+adrsize); { handler address }
           a1 := getadr(params+adrsize+ptrsize); { handler frame }
           { only global-level handlers: nested ones need the
             planned thunk securing }
           if ad2 <> 0 then if a1 <> globalframe then
              errore(FunctionNotImplemented);
           putint(ad, vmhandall);
           vmhandall := ad2;
           if not hookedall then begin

              graphics.eventsover(evtsthunk, a3);
              hookedall := true

           end;
           params := params+adrsize+ptrsize*2

       end;

    else errore(FunctionNotImplemented)

    end

end;

