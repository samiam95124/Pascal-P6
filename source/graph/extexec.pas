{ place event record to client memory }

procedure putevt(view er: graphics.evtrec; ad: address);

begin

   putint(ad, er.winid); { winid at 0 }
   putbyt(ad+8, ord(er.handled)); { handled at 8 }
   putbyt(ad+9, ord(er.etype)); { etype tag at 9 }
   case er.etype of { variant data, reverse order from 12 }

      graphics.etchar: putbyt(ad+12, ord(er.echar));
      graphics.etfun: putint(ad+12, er.fkey);
      graphics.etmouba: begin putint(ad+20, er.amoun);
         putint(ad+12, er.amoubn) end;
      graphics.etmoubd: begin putint(ad+20, er.dmoun);
         putint(ad+12, er.dmoubn) end;
      graphics.etmoumov: begin putint(ad+28, er.mmoun);
         putint(ad+20, er.moupx);
         putint(ad+12, er.moupy) end;
      graphics.ettim: putint(ad+12, er.timnum);
      graphics.etjoyba: begin putint(ad+20, er.ajoyn);
         putint(ad+12, er.ajoybn) end;
      graphics.etjoybd: begin putint(ad+20, er.djoyn);
         putint(ad+12, er.djoybn) end;
      graphics.etjoymov: begin putint(ad+60, er.mjoyn);
         putint(ad+52, er.joypx);
         putint(ad+44, er.joypy);
         putint(ad+36, er.joypz);
         putint(ad+28, er.joyp4);
         putint(ad+20, er.joyp5);
         putint(ad+12, er.joyp6) end;
      graphics.etresize: begin putint(ad+36, er.rszx);
         putint(ad+28, er.rszy);
         putint(ad+20, er.rszxg);
         putint(ad+12, er.rszyg) end;
      graphics.etmoumovg: begin putint(ad+28, er.mmoung);
         putint(ad+20, er.moupxg);
         putint(ad+12, er.moupyg) end;
      graphics.etredraw: begin putint(ad+36, er.rsx);
         putint(ad+28, er.rsy);
         putint(ad+20, er.rex);
         putint(ad+12, er.rey) end;
      graphics.etmenus: putint(ad+12, er.menuid);
      graphics.etbutton: putint(ad+12, er.butid);
      graphics.etchkbox: putint(ad+12, er.ckbxid);
      graphics.etradbut: putint(ad+12, er.radbid);
      graphics.etsclull: putint(ad+12, er.sclulid);
      graphics.etscldrl: putint(ad+12, er.scldrid);
      graphics.etsclulp: putint(ad+12, er.sclupid);
