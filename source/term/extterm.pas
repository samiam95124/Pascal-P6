           a := getint(params);
           terminal.autohold(a <> 0);
           params := params+intsize;

       end;

       82: begin { wrtstr@p_fc_vc }

           ad := getadr(params+strparsiz); valfil(ad); fn := getbyt(ad);
           if fn > commandfn then errore(FileModeIncorrect);
           getstr(params, s);
           terminal.wrtstr(output, s);
           params := params+adrsize+strparsiz;

       end;

