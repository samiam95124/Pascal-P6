function int2color(i: integer): terminal.color;

var c: terminal.color;

begin

   case i of
      0: c := terminal.black;
      1: c := terminal.white;
      2: c := terminal.red;
      3: c := terminal.green;
      4: c := terminal.blue;
      5: c := terminal.cyan;
      6: c := terminal.yellow;
      7: c := terminal.magenta;
   else c := terminal.black
   end;
   int2color := c

end;


