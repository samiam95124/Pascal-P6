{ Certificate-list translation. The native network.certlist* routines build a
  linked list/tree of certfield records (name@0 data@8 critical@16 fork@20
  next@28, record size 36, with name/data as pstrings). putcertlist rebuilds it
  in vm memory, freeing the native side; freecertlist frees the vm structure. }

function putcertlist(cp: network.certptr): address;

var ad, sa: address;
    l, i:   integer;
    lp:     network.certptr;

begin

   if cp = nil then putcertlist := nilval
   else begin

      newspc(36, ad); { a certfield record in interpreted layout }
      { name pstring at +0 }
      if cp^.name = nil then putadr(ad, nilval)
      else begin
         l := max(cp^.name^);
         newspc(intsize+l, sa);
         putint(sa, l);
         for i := 1 to l do putbyt(sa+intsize+i-1, ord(cp^.name^[i]));
         putadr(ad, sa)
      end;
      { data pstring at +8 }
      if cp^.data = nil then putadr(ad+8, nilval)
      else begin
         l := max(cp^.data^);
         newspc(intsize+l, sa);
         putint(sa, l);
         for i := 1 to l do putbyt(sa+intsize+i-1, ord(cp^.data^[i]));
         putadr(ad+8, sa)
      end;
      putbyt(ad+16, ord(cp^.critical)); { critical at +16 }
      putadr(ad+20, putcertlist(cp^.fork)); { fork sublist at +20 }
      putadr(ad+28, putcertlist(cp^.next)); { next at +28 }
      { release the native entry; the sublist and next are freed by recursion }
      lp := cp;
      if lp^.name <> nil then dispose(lp^.name);
      if lp^.data <> nil then dispose(lp^.data);
      dispose(lp);
      putcertlist := ad

   end

end;

procedure freecertlist(ad: address);

var sa: address;

begin

   if (ad <> 0) and (ad <> nilval) then begin

      sa := getadr(ad); { name string }
      if (sa <> 0) and (sa <> nilval) then dspspc(0, sa);
      sa := getadr(ad+8); { data string }
      if (sa <> 0) and (sa <> nilval) then dspspc(0, sa);
      freecertlist(getadr(ad+20)); { fork sublist }
      freecertlist(getadr(ad+28)); { next entry }
      dspspc(0, ad) { the record }

   end

end;

procedure execnetwork(routine: integer; var params: integer);

var a1, a2, a3, a4, a5, a6, rv: integer;
    s: str;
    ad, ad2:  address;
    fn:       fileno;
    bp:       bytconp;
    cp:       network.certptr;
    lcardinal1, lcardinal2: lcardinal;

begin

    case routine of

       1: begin { addrnet@p_vc_x(0,9223372036854775807)i }

           getstr(params+adrsize, s);
           a1 := getadr(params);
           lcardinal1 := 0;
           network.addrnet(s, lcardinal1);
           putint(a1, lcardinal1);
           params := params+strparsiz+adrsize;

       end;

       2: begin { addrnetv6@p_vc_x(0,9223372036854775807)i_x(0,92233 }

           getstr(params+adrsize+adrsize, s);
           a1 := getadr(params+adrsize);
           lcardinal1 := 0;
           a2 := getadr(params);
           lcardinal2 := 0;
           network.addrnetv6(s, lcardinal1, lcardinal2);
           putint(a1, lcardinal1);
           putint(a2, lcardinal2);
           params := params+strparsiz+adrsize+adrsize;

       end;

       3: begin { maxmsg@f_x(0,9223372036854775807)i }

           a1 := getint(params);
           rv := ord(network.maxmsg(a1));
           params := params+intsize;
           putint(params, rv);

       end;

       4: begin { maxmsgv6@f_x(0,9223372036854775807)i_x(0,92233720 }

           a1 := getint(params+intsize);
           a2 := getint(params);
           rv := ord(network.maxmsgv6(a1, a2));
           params := params+intsize+intsize;
           putint(params, rv);

       end;

       5: begin { relymsg@f_x(0,9223372036854775807)i }

           a1 := getint(params);
           rv := ord(network.relymsg(a1));
           params := params+intsize;
           putint(params, rv);

       end;

       6: begin { relymsgv6@f_x(0,9223372036854775807)i_x(0,92233720 }

           a1 := getint(params+intsize);
           a2 := getint(params);
           rv := ord(network.relymsgv6(a1, a2));
           params := params+intsize+intsize;
           putint(params, rv);

       end;

       7: begin { openmsg@f_x(0,9223372036854775807)i_i_i }

           a1 := getint(params+intsize+intsize);
           a2 := getint(params+intsize);
           a3 := getint(params);
           rv := ord(network.openmsg(a1, a2, a3));
           params := params+intsize+intsize+intsize;
           putint(params, rv);

       end;

       8: begin { openmsgv6@f_x(0,9223372036854775807)i_x(0,92233720 }

           a1 := getint(params+intsize+intsize+intsize);
           a2 := getint(params+intsize+intsize);
           a3 := getint(params+intsize);
           a4 := getint(params);
           rv := ord(network.openmsgv6(a1, a2, a3, a4));
           params := params+intsize+intsize+intsize+intsize;
           putint(params, rv);

       end;

       9: begin { wrmsg@p_i_vx(0,255)i }

           a1 := getint(params+strparsiz);
           getabyte(params, bp);
           network.wrmsg(a1, bp^);
           dispose(bp);
           params := params+intsize+strparsiz;

       end;

       10: begin { rdmsg@f_i_vx(0,255)i }

           a1 := getint(params+strparsiz);
           newabyte(params, bp);
           rv := ord(network.rdmsg(a1, bp^));
           putabyte(params, bp);
           params := params+intsize+strparsiz;
           putint(params, rv);

       end;

       11: begin { clsmsg@p_i }

           a1 := getint(params);
           network.clsmsg(a1);
           params := params+intsize;

       end;

       12: begin { waitmsg@f_i_i }

           a1 := getint(params+intsize);
           a2 := getint(params);
           rv := ord(network.waitmsg(a1, a2));
           params := params+intsize+intsize;
           putint(params, rv);

       end;

       13: begin { certmsg@f_i_i_vc }

           a1 := getint(params+strparsiz+intsize);
           a2 := getint(params+strparsiz);
           a3 := params; { var string base }
           for rv := 1 to strmax do s[rv] := ' ';
           rv := ord(network.certmsg(a1, a2, s));
           putstr(s, a3);
           params := params+intsize+intsize+strparsiz;
           putint(params, rv);

       end;

       14: begin { opennet@p_fc_fc_x(0,9223372036854775807)i_i_i }

           ad := getadr(params+intsize+intsize+intsize+adrsize); valfil(ad); fn := getbyt(ad);
           if fn <= commandfn then errore(FileModeIncorrect);
           a1 := fn;
           ad := getadr(params+intsize+intsize+intsize); valfil(ad); fn := getbyt(ad);
           if fn <= commandfn then errore(FileModeIncorrect);
           a2 := fn;
           a3 := getint(params+intsize+intsize);
           a4 := getint(params+intsize);
           a5 := getint(params);
           network.opennet(filtable[a1], filtable[a2], a3, a4, a5);
           { the bound connection files become readable and writable }
           filstate[a1] := fread;
           filstate[a2] := fwrite;
           params := params+adrsize+adrsize+intsize+intsize+intsize;

       end;

       15: begin { opennetv6@p_fc_fc_x(0,9223372036854775807)i_x(0,92 }

           ad := getadr(params+intsize+intsize+intsize+intsize+adrsize); valfil(ad); fn := getbyt(ad);
           if fn <= commandfn then errore(FileModeIncorrect);
           a1 := fn;
           ad := getadr(params+intsize+intsize+intsize+intsize); valfil(ad); fn := getbyt(ad);
           if fn <= commandfn then errore(FileModeIncorrect);
           a2 := fn;
           a3 := getint(params+intsize+intsize+intsize);
           a4 := getint(params+intsize+intsize);
           a5 := getint(params+intsize);
           a6 := getint(params);
           network.opennetv6(filtable[a1], filtable[a2], a3, a4, a5, a6);
           { the bound connection files become readable and writable }
           filstate[a1] := fread;
           filstate[a2] := fwrite;
           params := params+adrsize+adrsize+intsize+intsize+intsize+intsize;

       end;

       16: begin { waitnet@p_fc_fc_i_i }

           ad := getadr(params+intsize+intsize+adrsize); valfil(ad); fn := getbyt(ad);
           if fn <= commandfn then errore(FileModeIncorrect);
           a1 := fn;
           ad := getadr(params+intsize+intsize); valfil(ad); fn := getbyt(ad);
           if fn <= commandfn then errore(FileModeIncorrect);
           a2 := fn;
           a3 := getint(params+intsize);
           a4 := getint(params);
           network.waitnet(filtable[a1], filtable[a2], a3, a4);
           { the bound connection files become readable and writable }
           filstate[a1] := fread;
           filstate[a2] := fwrite;
           params := params+adrsize+adrsize+intsize+intsize;

       end;

       17: begin { certnet@f_fc_i_vc }

           ad := getadr(params+strparsiz+intsize); valfil(ad); fn := getbyt(ad);
           if fn <= commandfn then errore(FileModeIncorrect);
           a1 := fn;
           a2 := getint(params+strparsiz);
           a3 := params; { var string base }
           for rv := 1 to strmax do s[rv] := ' ';
           rv := ord(network.certnet(filtable[a1], a2, s));
           putstr(s, a3);
           params := params+adrsize+intsize+strparsiz;
           putint(params, rv);

       end;

       18: begin { certlistnet@p_fc_i_pr }

           ad := getadr(params+adrsize+intsize); valfil(ad); fn := getbyt(ad);
           if fn <= commandfn then errore(FileModeIncorrect);
           a1 := fn;
           a2 := getint(params+adrsize); { which }
           ad2 := getadr(params); { var list result cell }
           cp := nil;
           network.certlistnet(filtable[a1], a2, cp);
           putadr(ad2, putcertlist(cp));
           params := params+adrsize+intsize+adrsize

       end;

       19: begin { certlistmsg@p_i_i_pr }

           a1 := getint(params+adrsize+intsize); { connection }
           a2 := getint(params+adrsize); { which }
           ad2 := getadr(params); { var list result cell }
           cp := nil;
           network.certlistmsg(a1, a2, cp);
           putadr(ad2, putcertlist(cp));
           params := params+intsize+intsize+adrsize

       end;

       20: begin { certlistfree@p_pr }

           ad2 := getadr(params); { var list cell }
           freecertlist(getadr(ad2));
           putadr(ad2, nilval);
           params := params+adrsize

       end;

    else errore(FunctionNotImplemented)

    end

end;

